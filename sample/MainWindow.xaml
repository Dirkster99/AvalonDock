<Window x:Class="AvalonDock.Sample.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:dock="clr-namespace:AvalonDock;assembly=AvalonDock"
        xmlns:dockLayout="clr-namespace:AvalonDock.Layout;assembly=AvalonDock"
        xmlns:dockThemes="clr-namespace:AvalonDock.Themes;assembly=AvalonDock.Themes.VS2013"
        xmlns:reskeys="clr-namespace:AvalonDock.Themes.VS2013.Themes;assembly=AvalonDock.Themes.VS2013"
        Title="UnoDock Sample — AvalonDock on Uno Platform"
        Width="1600"
        Height="900">

    <Grid>
        <Grid.Resources>
            <SolidColorBrush x:Key="SampleTextPrimary" Color="#FF1F1F1F" />
            <SolidColorBrush x:Key="SampleTextSecondary" Color="#FF3A3A3A" />
            <SolidColorBrush x:Key="SampleTextMuted" Color="#FF6B6B6B" />
            <SolidColorBrush x:Key="SampleCodeBackground" Color="#FFF7F7F7" />
            <SolidColorBrush x:Key="SampleCodeKeyword" Color="#FF0000CC" />
            <SolidColorBrush x:Key="SampleCodeType" Color="#FF2B91AF" />
            <SolidColorBrush x:Key="SampleCodeString" Color="#FFA31515" />
            <SolidColorBrush x:Key="SampleCodeOk" Color="#FF107C10" />
            <SolidColorBrush x:Key="SampleCodeWarn" Color="#FF7A5E00" />
        </Grid.Resources>

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="{DynamicResource {x:Static reskeys:ResourceKeys.Background}}"
                Padding="4,2">
            <Grid>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Margin="0,0,16,0" Text="File" Foreground="{DynamicResource {x:Static reskeys:ResourceKeys.ToolWindowTabUnselectedText}}" FontSize="12" VerticalAlignment="Center" />
                    <TextBlock Margin="0,0,16,0" Text="Edit" Foreground="{DynamicResource {x:Static reskeys:ResourceKeys.ToolWindowTabUnselectedText}}" FontSize="12" VerticalAlignment="Center" />
                    <TextBlock Margin="0,0,16,0" Text="View" Foreground="{DynamicResource {x:Static reskeys:ResourceKeys.ToolWindowTabUnselectedText}}" FontSize="12" VerticalAlignment="Center" />
                    <TextBlock Margin="0,0,16,0" Text="Project" Foreground="{DynamicResource {x:Static reskeys:ResourceKeys.ToolWindowTabUnselectedText}}" FontSize="12" VerticalAlignment="Center" />
                    <TextBlock Margin="0,0,16,0" Text="Debug" Foreground="{DynamicResource {x:Static reskeys:ResourceKeys.ToolWindowTabUnselectedText}}" FontSize="12" VerticalAlignment="Center" />
                    <TextBlock Text="Help" Foreground="{DynamicResource {x:Static reskeys:ResourceKeys.ToolWindowTabUnselectedText}}" FontSize="12" VerticalAlignment="Center" />
                </StackPanel>

                <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
                    <Button Margin="0,0,4,0"
                            VerticalAlignment="Center"
                            Padding="6,2"
                            Background="{DynamicResource {x:Static reskeys:ResourceKeys.TabBackground}}"
                            Foreground="{DynamicResource {x:Static reskeys:ResourceKeys.ToolWindowTabUnselectedText}}"
                            FontSize="11"
                            BorderThickness="0"
                            Content="💾 Save Layout"
                            AutomationProperties.AutomationId="SaveLayout"
                            Click="OnSaveLayoutClick" />
                    <Button Margin="0,0,4,0"
                            VerticalAlignment="Center"
                            Padding="6,2"
                            Background="{DynamicResource {x:Static reskeys:ResourceKeys.TabBackground}}"
                            Foreground="{DynamicResource {x:Static reskeys:ResourceKeys.ToolWindowTabUnselectedText}}"
                            FontSize="11"
                            BorderThickness="0"
                            Content="📂 Load Layout"
                            AutomationProperties.AutomationId="LoadLayout"
                            Click="OnLoadLayoutClick" />
                    <Button Margin="0,0,4,0"
                            VerticalAlignment="Center"
                            Padding="8,2"
                            Background="{DynamicResource {x:Static reskeys:ResourceKeys.DocumentWellTabSelectedActiveBackground}}"
                            Foreground="{DynamicResource {x:Static reskeys:ResourceKeys.DocumentWellTabSelectedActiveText}}"
                            FontSize="11"
                            BorderThickness="0"
                            Content="⬆ Float Active Tab"
                            AutomationProperties.AutomationId="FloatActiveTab"
                            Click="OnFloatActiveClick" />
                    <Button VerticalAlignment="Center"
                            Padding="8,2"
                            Background="{DynamicResource {x:Static reskeys:ResourceKeys.DocumentWellTabSelectedActiveBackground}}"
                            Foreground="{DynamicResource {x:Static reskeys:ResourceKeys.DocumentWellTabSelectedActiveText}}"
                            FontSize="11"
                            BorderThickness="0"
                            Content="🧭 Show Compass"
                            AutomationProperties.AutomationId="ShowCompass"
                            Click="OnShowCompassClick" />
                </StackPanel>
            </Grid>
        </Border>

        <dock:DockingManager Grid.Row="1"
                             x:Name="DockManager"
                             AutomationProperties.AutomationId="DockManager">
            <dock:DockingManager.Theme>
                <dockThemes:Vs2013LightTheme />
            </dock:DockingManager.Theme>
            <dock:DockingManager.Layout>
                <dockLayout:LayoutRoot>
                    <dockLayout:LayoutPanel Orientation="Horizontal">
                        <dockLayout:LayoutAnchorablePane DockWidth="220">
                            <dockLayout:LayoutAnchorable Title="Solution Explorer"
                                                         ContentId="solution-explorer">
                                <StackPanel Margin="8">
                                    <TextBlock Margin="0,0,0,6" Text="🔍 Search (Ctrl+;)" Foreground="{StaticResource SampleTextMuted}" FontSize="11" />
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,2">
                                        <TextBlock Margin="0,0,4,0" Text="▶" Foreground="{StaticResource SampleTextPrimary}" FontSize="11" />
                                        <TextBlock Text="UnoDock.Sample" Foreground="{StaticResource SampleTextPrimary}" FontSize="12" FontWeight="SemiBold" />
                                    </StackPanel>
                                    <StackPanel Margin="16,0,0,0">
                                        <TextBlock Margin="0,0,0,2" Text="📁 src" Foreground="{StaticResource SampleTextPrimary}" FontSize="12" />
                                        <StackPanel Margin="16,0,0,0">
                                            <TextBlock Margin="0,0,0,1" Text="📄 App.xaml" Foreground="{StaticResource SampleTextPrimary}" FontSize="12" />
                                            <TextBlock Margin="0,0,0,1" Text="📄 App.xaml.cs" Foreground="{StaticResource SampleTextPrimary}" FontSize="12" />
                                            <TextBlock Margin="0,0,0,1" Text="📄 MainWindow.xaml" Foreground="{StaticResource SampleCodeType}" FontSize="12" />
                                            <TextBlock Text="📄 MainWindow.xaml.cs" Foreground="{StaticResource SampleTextPrimary}" FontSize="12" />
                                        </StackPanel>
                                        <TextBlock Margin="0,2,0,0" Text="📁 Platforms" Foreground="{StaticResource SampleTextPrimary}" FontSize="12" />
                                        <TextBlock Text="📄 UnoDock.Sample.csproj" Foreground="{StaticResource SampleCodeString}" FontSize="12" />
                                    </StackPanel>
                                </StackPanel>
                            </dockLayout:LayoutAnchorable>

                            <dockLayout:LayoutAnchorable Title="Git Changes"
                                                         ContentId="git-changes">
                                <StackPanel Margin="8">
                                    <TextBlock Margin="0,0,0,6" Text="main ↑0 ↓0" Foreground="{StaticResource SampleCodeOk}" FontSize="12" />
                                    <TextBlock Margin="0,0,0,2" Text="Staged Changes (0)" Foreground="{StaticResource SampleTextMuted}" FontSize="11" />
                                    <TextBlock Margin="0,0,0,2" Text="Changes (3)" Foreground="{StaticResource SampleTextMuted}" FontSize="11" />
                                    <StackPanel Margin="8,0,0,0">
                                        <TextBlock Margin="0,0,0,2" Text="M  Themes/Generic.xaml" Foreground="{StaticResource SampleCodeWarn}" FontSize="11" />
                                        <TextBlock Margin="0,0,0,2" Text="M  Controls/LayoutDocumentPaneControl.cs" Foreground="{StaticResource SampleCodeWarn}" FontSize="11" />
                                        <TextBlock Text="M  Controls/DockingManager.cs" Foreground="{StaticResource SampleCodeWarn}" FontSize="11" />
                                    </StackPanel>
                                </StackPanel>
                            </dockLayout:LayoutAnchorable>
                        </dockLayout:LayoutAnchorablePane>

                        <dockLayout:LayoutDocumentPane>
                            <dockLayout:LayoutDocument Title="MainWindow.xaml"
                                                       ContentId="main-window-xaml">
                                <ScrollViewer Padding="12" Background="{StaticResource SampleCodeBackground}">
                                    <StackPanel>
                                        <TextBlock FontFamily="Cascadia Code, Consolas" FontSize="13">
                                            <Run Foreground="{StaticResource SampleTextMuted}">&lt;</Run>
                                            <Run Foreground="{StaticResource SampleCodeOk}">Window</Run>
                                        </TextBlock>
                                        <TextBlock Margin="16,0,0,0"
                                                   Text="    x:Class=&quot;UnoDock.Sample.MainWindow&quot;"
                                                   FontFamily="Cascadia Code, Consolas"
                                                   FontSize="13"
                                                   Foreground="{StaticResource SampleCodeType}" />
                                        <TextBlock Margin="16,0,0,0"
                                                   Text="    xmlns=&quot;http://schemas.microsoft.com/...&quot;"
                                                   FontFamily="Cascadia Code, Consolas"
                                                   FontSize="13"
                                                   Foreground="{StaticResource SampleCodeString}" />
                                        <TextBlock Margin="16,0,0,0"
                                                   Text="    Title=&quot;UnoDock Sample&quot;&gt;"
                                                   FontFamily="Cascadia Code, Consolas"
                                                   FontSize="13"
                                                   Foreground="{StaticResource SampleCodeString}" />
                                        <TextBlock Margin="0,8,0,0" FontFamily="Cascadia Code, Consolas" FontSize="13">
                                            <Run Foreground="{StaticResource SampleTextMuted}">  &lt;</Run>
                                            <Run Foreground="{StaticResource SampleCodeOk}">dock:DockingManager</Run>
                                            <Run Foreground="{StaticResource SampleCodeType}"> x:Name=</Run>
                                            <Run Foreground="{StaticResource SampleCodeString}">&quot;DockManager&quot;</Run>
                                            <Run Foreground="{StaticResource SampleTextMuted}">&gt;</Run>
                                        </TextBlock>
                                        <TextBlock Text="    ..." FontFamily="Cascadia Code, Consolas" FontSize="13" Foreground="{StaticResource SampleTextMuted}" />
                                        <TextBlock FontFamily="Cascadia Code, Consolas" FontSize="13">
                                            <Run Foreground="{StaticResource SampleTextMuted}">  &lt;/</Run>
                                            <Run Foreground="{StaticResource SampleCodeOk}">dock:DockingManager</Run>
                                            <Run Foreground="{StaticResource SampleTextMuted}">&gt;</Run>
                                        </TextBlock>
                                        <TextBlock FontFamily="Cascadia Code, Consolas" FontSize="13">
                                            <Run Foreground="{StaticResource SampleTextMuted}">&lt;/</Run>
                                            <Run Foreground="{StaticResource SampleCodeOk}">Window</Run>
                                            <Run Foreground="{StaticResource SampleTextMuted}">&gt;</Run>
                                        </TextBlock>
                                    </StackPanel>
                                </ScrollViewer>
                            </dockLayout:LayoutDocument>

                            <dockLayout:LayoutDocument Title="DockingManager.cs"
                                                       ContentId="docking-manager-cs">
                                <ScrollViewer Padding="12" Background="{StaticResource SampleCodeBackground}">
                                    <StackPanel>
                                        <TextBlock FontFamily="Cascadia Code, Consolas" FontSize="13">
                                            <Run Foreground="{StaticResource SampleCodeKeyword}">public partial class </Run>
                                            <Run Foreground="{StaticResource SampleCodeOk}">DockingManager</Run>
                                            <Run Foreground="{StaticResource SampleTextPrimary}"> : </Run>
                                            <Run Foreground="{StaticResource SampleCodeOk}">Control</Run>
                                            <Run Foreground="{StaticResource SampleTextPrimary}">, </Run>
                                            <Run Foreground="{StaticResource SampleCodeOk}">IOverlayWindowHost</Run>
                                        </TextBlock>
                                        <TextBlock Text="{}{}" FontFamily="Cascadia Code, Consolas" FontSize="13" Foreground="{StaticResource SampleTextPrimary}" />
                                        <TextBlock Margin="16,0,0,0" FontFamily="Cascadia Code, Consolas" FontSize="13">
                                            <Run Foreground="{StaticResource SampleCodeKeyword}">    public </Run>
                                            <Run Foreground="{StaticResource SampleCodeOk}">DockingManager</Run>
                                            <Run Foreground="{StaticResource SampleTextPrimary}">()</Run>
                                        </TextBlock>
                                        <TextBlock Text="    {" FontFamily="Cascadia Code, Consolas" FontSize="13" Foreground="{StaticResource SampleTextPrimary}" />
                                        <TextBlock Margin="16,0,0,0"
                                                   Text="        DefaultStyleKey = typeof(DockingManager);"
                                                   FontFamily="Cascadia Code, Consolas"
                                                   FontSize="13"
                                                   Foreground="{StaticResource SampleTextPrimary}" />
                                        <TextBlock Margin="16,0,0,0"
                                                   Text="        Layout = new LayoutRoot {...};"
                                                   FontFamily="Cascadia Code, Consolas"
                                                   FontSize="13"
                                                   Foreground="{StaticResource SampleTextPrimary}" />
                                        <TextBlock Text="    }" FontFamily="Cascadia Code, Consolas" FontSize="13" Foreground="{StaticResource SampleTextPrimary}" />
                                        <TextBlock Text="}" FontFamily="Cascadia Code, Consolas" FontSize="13" Foreground="{StaticResource SampleTextPrimary}" />
                                    </StackPanel>
                                </ScrollViewer>
                            </dockLayout:LayoutDocument>

                            <dockLayout:LayoutDocument Title="README.md"
                                                       ContentId="readme">
                                <ScrollViewer Padding="16" Background="{StaticResource SampleCodeBackground}">
                                    <StackPanel>
                                        <TextBlock Text="# UnoDock" FontSize="22" FontWeight="Bold" Foreground="{StaticResource SampleTextPrimary}" />
                                        <TextBlock Margin="0,8,0,0" Text="AvalonDock ported to Uno Platform" FontSize="14" Foreground="{StaticResource SampleCodeType}" />
                                        <TextBlock Margin="0,8,0,0"
                                                   Text="A faithful source port of Dirkster99/AvalonDock targeting net10.0-desktop (Skia: macOS, Linux, Windows) and net10.0-windows10.0.19041.0 (WinUI 3)."
                                                   TextWrapping="Wrap"
                                                   Foreground="{StaticResource SampleTextSecondary}"
                                                   FontSize="13" />
                                        <TextBlock Margin="0,16,0,0" Text="## Status" FontSize="16" FontWeight="Bold" Foreground="{StaticResource SampleTextPrimary}" />
                                        <TextBlock Margin="0,8,0,0" Text="✅ Model layer (33 tests green)" Foreground="{StaticResource SampleCodeOk}" FontSize="13" />
                                        <TextBlock Margin="0,4,0,0" Text="✅ Static layout rendering" Foreground="{StaticResource SampleCodeOk}" FontSize="13" />
                                        <TextBlock Margin="0,4,0,0" Text="✅ Tab selection + content" Foreground="{StaticResource SampleCodeOk}" FontSize="13" />
                                        <TextBlock Margin="0,4,0,0" Text="✅ Splitter drag resize" Foreground="{StaticResource SampleCodeOk}" FontSize="13" />
                                        <TextBlock Margin="0,4,0,0" Text="✅ Tab close (×)" Foreground="{StaticResource SampleCodeOk}" FontSize="13" />
                                        <TextBlock Margin="0,4,0,0" Text="⬜ Floating windows (Phase 5)" Foreground="{StaticResource SampleTextMuted}" FontSize="13" />
                                        <TextBlock Margin="0,4,0,0" Text="⬜ Auto-hide (Phase 6)" Foreground="{StaticResource SampleTextMuted}" FontSize="13" />
                                        <TextBlock Margin="0,4,0,0" Text="⬜ Drag-drop compass (Phase 4)" Foreground="{StaticResource SampleTextMuted}" FontSize="13" />
                                    </StackPanel>
                                </ScrollViewer>
                            </dockLayout:LayoutDocument>
                        </dockLayout:LayoutDocumentPane>

                        <dockLayout:LayoutAnchorablePane DockWidth="200">
                            <dockLayout:LayoutAnchorable Title="Properties"
                                                         ContentId="properties">
                                <StackPanel Margin="8">
                                    <TextBlock Text="DockingManager" FontWeight="Bold" Foreground="{StaticResource SampleTextPrimary}" FontSize="12" />
                                    <Grid Margin="0,4,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>
                                        <TextBlock Grid.Row="0" Grid.Column="0" Text="GridSplitterWidth" Foreground="{StaticResource SampleCodeType}" FontSize="11" />
                                        <TextBlock Grid.Row="0" Grid.Column="1" Text="6" Foreground="{StaticResource SampleCodeString}" FontSize="11" />
                                        <TextBlock Grid.Row="1" Grid.Column="0" Text="GridSplitterHeight" Foreground="{StaticResource SampleCodeType}" FontSize="11" />
                                        <TextBlock Grid.Row="1" Grid.Column="1" Text="6" Foreground="{StaticResource SampleCodeString}" FontSize="11" />
                                        <TextBlock Grid.Row="2" Grid.Column="0" Text="IsVirtualizing" Foreground="{StaticResource SampleCodeType}" FontSize="11" />
                                        <TextBlock Grid.Row="2" Grid.Column="1" Text="True" Foreground="{StaticResource SampleCodeKeyword}" FontSize="11" />
                                    </Grid>
                                </StackPanel>
                            </dockLayout:LayoutAnchorable>

                            <dockLayout:LayoutAnchorable Title="Output"
                                                         ContentId="output">
                                <ScrollViewer Background="{StaticResource SampleCodeBackground}" Padding="8">
                                    <StackPanel>
                                        <TextBlock Margin="0,0,0,2" Text="Build started..." Foreground="{StaticResource SampleTextMuted}" FontFamily="Cascadia Code, Consolas" FontSize="11" />
                                        <TextBlock Margin="0,0,0,2" Text="  UnoDock → 0 errors, 87 warnings" Foreground="{StaticResource SampleTextPrimary}" FontFamily="Cascadia Code, Consolas" FontSize="11" />
                                        <TextBlock Margin="0,0,0,2" Text="  UnoDock.Tests → 33/33 passed" Foreground="{StaticResource SampleCodeOk}" FontFamily="Cascadia Code, Consolas" FontSize="11" />
                                        <TextBlock Margin="0,0,0,2" Text="  UnoDock.Sample → ok" Foreground="{StaticResource SampleCodeOk}" FontFamily="Cascadia Code, Consolas" FontSize="11" />
                                        <TextBlock Text="Build succeeded." FontWeight="Bold" Foreground="{StaticResource SampleCodeOk}" FontFamily="Cascadia Code, Consolas" FontSize="11" />
                                    </StackPanel>
                                </ScrollViewer>
                            </dockLayout:LayoutAnchorable>
                        </dockLayout:LayoutAnchorablePane>
                    </dockLayout:LayoutPanel>
                </dockLayout:LayoutRoot>
            </dock:DockingManager.Layout>
        </dock:DockingManager>

        <Border Grid.Row="2"
                Background="{DynamicResource {x:Static reskeys:ResourceKeys.DocumentWellTabSelectedActiveBackground}}"
                Padding="8,2">
            <StackPanel Orientation="Horizontal">
                <TextBlock Margin="0,0,16,0" Text="🔀 main" Foreground="{DynamicResource {x:Static reskeys:ResourceKeys.DocumentWellTabSelectedActiveText}}" FontSize="11" />
                <TextBlock Margin="0,0,16,0" Text="⚠ 0   ✕ 0" Foreground="{DynamicResource {x:Static reskeys:ResourceKeys.DocumentWellTabSelectedActiveText}}" FontSize="11" />
                <TextBlock Margin="0,0,16,0" Text="Ln 1, Col 1" Foreground="{DynamicResource {x:Static reskeys:ResourceKeys.DocumentWellTabSelectedActiveText}}" FontSize="11" />
                <TextBlock Margin="0,0,16,0" Text="Spaces: 4" Foreground="{DynamicResource {x:Static reskeys:ResourceKeys.DocumentWellTabSelectedActiveText}}" FontSize="11" />
                <TextBlock Text="UTF-8" Foreground="{DynamicResource {x:Static reskeys:ResourceKeys.DocumentWellTabSelectedActiveText}}" FontSize="11" />
            </StackPanel>
        </Border>
    </Grid>
</Window>
