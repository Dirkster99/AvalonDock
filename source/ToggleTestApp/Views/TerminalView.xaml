<UserControl x:Class="ToggleTestApp.Views.TerminalView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:terminal="clr-namespace:Simple.Wpf.Terminal;assembly=Simple.Wpf.Terminal"
             Background="#1E1E1E"
             Loaded="OnLoaded"
             Unloaded="OnUnloaded">
    <terminal:Terminal x:Name="Terminal"
                      Background="#1E1E1E"
                      Foreground="#CCCCCC"
                      FontFamily="Consolas"
                      FontSize="13"
                      BorderThickness="0"
                      Padding="8,4"
                      IsReadOnly="False"
                      ItemsSource="{Binding OutputLines}"
                      ItemDisplayPath="Value" />
</UserControl>
