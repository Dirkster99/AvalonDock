<UserControl x:Class="ToggleTestApp.Views.FolderExplorerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:ToggleTestApp.ViewModels"
             Background="#252526">
    <UserControl.Resources>
        <HierarchicalDataTemplate DataType="{x:Type vm:FileTreeItem}"
                                  ItemsSource="{Binding Children}">
            <StackPanel Orientation="Horizontal" Margin="2,1">
                <!-- Folder/File icon -->
                <TextBlock Text="{Binding IsDirectory, Converter={StaticResource FileIconConverter}}"
                           FontFamily="Segoe MDL2 Assets" FontSize="12"
                           Foreground="{Binding IsDirectory, Converter={StaticResource FileColorConverter}}"
                           Margin="0,0,6,0" VerticalAlignment="Center" />
                <TextBlock Text="{Binding Name}" Foreground="#CCCCCC" FontSize="12"
                           VerticalAlignment="Center" />
            </StackPanel>
        </HierarchicalDataTemplate>
    </UserControl.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="EXPLORER" FontSize="11" FontWeight="SemiBold"
                   Foreground="#BBBBBB" Margin="12,6,8,4" />

        <TreeView Grid.Row="1" ItemsSource="{Binding RootItems}"
                  Background="Transparent" BorderThickness="0"
                  VirtualizingPanel.IsVirtualizing="True">
            <TreeView.ItemContainerStyle>
                <Style TargetType="TreeViewItem">
                    <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}" />
                    <Setter Property="Foreground" Value="#CCCCCC" />
                    <EventSetter Event="Expanded" Handler="OnTreeViewItemExpanded" />
                    <EventSetter Event="MouseDoubleClick" Handler="OnTreeViewItemDoubleClick" />
                    <Style.Triggers>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter Property="Background" Value="#094771" />
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </TreeView.ItemContainerStyle>
        </TreeView>
    </Grid>
</UserControl>
