<Window x:Class="ToggleTestApp.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:avalonDock="https://github.com/Dirkster99/AvalonDock"
    xmlns:avalonDockControls="clr-namespace:AvalonDock.Controls;assembly=AvalonDock"
    xmlns:avalonDockThemes="clr-namespace:AvalonDock.Themes;assembly=AvalonDock.Themes.Arc"
    xmlns:views="clr-namespace:ToggleTestApp.Views"
    xmlns:vm="clr-namespace:ToggleTestApp.ViewModels"
    Title="AvalonDock Code — Toggle Docking Demo"
    Width="1100" Height="750"
    Background="#252729"
    UseLayoutRounding="True">
    <Window.Resources>
        <views:FileIconConverter x:Key="FileIconConverter" />
        <views:FileColorConverter x:Key="FileColorConverter" />
        <views:NullToCollapsedConverter x:Key="NullToCollapsedConverter" />
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter" />

        <!-- DataTemplate: how to render each toolbox VM's content -->
        <DataTemplate DataType="{x:Type vm:FolderExplorerViewModel}">
            <views:FolderExplorerView />
        </DataTemplate>

        <DataTemplate DataType="{x:Type vm:TerminalViewModel}">
            <views:TerminalView />
        </DataTemplate>

        <DataTemplate DataType="{x:Type vm:SearchViewModel}">
            <Border Background="#252526" Padding="12">
                <TextBox Background="#3C3C3C" Foreground="#CCCCCC" BorderThickness="0"
                         Padding="6,4" FontSize="12" VerticalAlignment="Top"
                         Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" />
            </Border>
        </DataTemplate>

        <DataTemplate DataType="{x:Type vm:SourceControlViewModel}">
            <Border Background="#252526" Padding="12">
                <TextBlock Text="{Binding Status}" Foreground="#808080" FontSize="12" />
            </Border>
        </DataTemplate>

        <DataTemplate DataType="{x:Type vm:ProblemsViewModel}">
            <Border Background="#1E1E1E" Padding="12">
                <TextBlock Text="{Binding Status}" Foreground="#808080" FontSize="12" />
            </Border>
        </DataTemplate>

        <!-- DataTemplate: how to render document content -->
        <DataTemplate DataType="{x:Type vm:EditorTabViewModel}">
            <views:EditorView />
        </DataTemplate>

        <!-- Document header template (tab header with icon + title) -->
        <DataTemplate x:Key="DocumentTabHeaderTemplate">
            <StackPanel Orientation="Horizontal">
                <Image Source="{Binding IconSource}" Width="14" Height="14"
                       Margin="0,0,5,0" VerticalAlignment="Center"
                       Visibility="{Binding IconSource, Converter={StaticResource NullToCollapsedConverter}}" />
                <TextBlock Text="{Binding Title}" TextTrimming="CharacterEllipsis"
                           VerticalAlignment="Center" />
            </StackPanel>
        </DataTemplate>

        <!-- LayoutItem style selector: different styles for toolboxes vs documents -->
        <views:PanesStyleSelector x:Key="PanesStyleSelector">
            <views:PanesStyleSelector.ToolboxStyle>
                <Style TargetType="{x:Type avalonDockControls:LayoutAnchorableItem}">
                    <Setter Property="Title" Value="{Binding Model.Title}" />
                    <Setter Property="ContentId" Value="{Binding Model.ContentId}" />
                    <Setter Property="ClipToBounds" Value="True" />
                </Style>
            </views:PanesStyleSelector.ToolboxStyle>
            <views:PanesStyleSelector.DocumentStyle>
                <Style TargetType="{x:Type avalonDockControls:LayoutDocumentItem}">
                    <Setter Property="Title" Value="{Binding Model.Title}" />
                    <Setter Property="ToolTip" Value="{Binding Model.ToolTip}" />
                    <Setter Property="IconSource" Value="{Binding Model.IconSource}" />
                    <Setter Property="ContentId" Value="{Binding Model.ContentId}" />
                </Style>
            </views:PanesStyleSelector.DocumentStyle>
        </views:PanesStyleSelector>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Title bar / Menu -->
        <Grid Grid.Row="0" Background="#252729">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Menu Grid.Column="0" Background="Transparent" Foreground="#CCCCCC" Padding="4,4">
                <Menu.Resources>
                    <Style TargetType="MenuItem">
                        <Setter Property="Foreground" Value="#CCCCCC" />
                        <Style.Triggers>
                            <Trigger Property="Role" Value="SubmenuHeader">
                                <Setter Property="Foreground" Value="Black" />
                            </Trigger>
                            <Trigger Property="Role" Value="SubmenuItem">
                                <Setter Property="Foreground" Value="Black" />
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Menu.Resources>
                <MenuItem Header="_File">
                    <MenuItem Header="_Open Folder..." Command="{Binding OpenFolderCommand}" />
                    <Separator />
                    <MenuItem Header="E_xit" Click="OnExit" />
                </MenuItem>
                <MenuItem Header="_View">
                    <MenuItem Header="Layout Priority">
                        <MenuItem x:Name="menuBottomFullWidth" Header="Bottom Full Width (Rider)"
                                  IsCheckable="True" IsChecked="True" Click="OnLayoutPriorityChanged" />
                        <MenuItem x:Name="menuSidesFullHeight" Header="Sides Full Height (VSCode)"
                                  IsCheckable="True" Click="OnLayoutPriorityChanged" />
                        <MenuItem x:Name="menuDefaultPriority" Header="Default (No Restructuring)"
                                  IsCheckable="True" Click="OnLayoutPriorityChanged" />
                    </MenuItem>
                </MenuItem>
            </Menu>
            <TextBlock Grid.Column="1" Text="AvalonDock Code — Toggle Docking Demo"
                       Foreground="#999999" FontSize="12"
                       HorizontalAlignment="Center" VerticalAlignment="Center" />
        </Grid>

        <!-- Dock Manager -->
        <avalonDock:ToggleDockingManager x:Name="dockManager" Grid.Row="1"
                                         BorderThickness="0"
                                         Background="#252729"
                                         DocumentsSource="{Binding OpenEditors}"
                                         AnchorablesSource="{Binding Toolboxes}"
                                         DocumentHeaderTemplate="{StaticResource DocumentTabHeaderTemplate}"
                                         LayoutItemContainerStyleSelector="{StaticResource PanesStyleSelector}">
            <avalonDock:ToggleDockingManager.Theme>
                <avalonDockThemes:ArcDarkTheme />
            </avalonDock:ToggleDockingManager.Theme>
            <avalonDock:LayoutRoot>
                <avalonDock:LayoutPanel Orientation="Horizontal">
                    <avalonDock:LayoutDocumentPaneGroup>
                        <avalonDock:LayoutDocumentPane x:Name="LayoutDocumentPane">
                            <avalonDock:LayoutDocument Title="Welcome" ContentId="welcome">
                                <Border Background="#1E1E1E" Padding="40">
                                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                        <TextBlock Text="AvalonDock Code" FontSize="28" FontWeight="Light"
                                                   Foreground="#CCCCCC" HorizontalAlignment="Center" />
                                        <TextBlock Text="Toggle Docking Demo — v5.0.0" FontSize="14"
                                                   Foreground="#808080" HorizontalAlignment="Center" Margin="0,8,0,24" />
                                        <TextBlock Foreground="#808080" FontSize="13" TextAlignment="Center" LineHeight="24">
                                            <Run Text="Click sidebar icons to toggle panels" /><LineBreak />
                                            <Run Text="Drag buttons between zones to rearrange" /><LineBreak />
                                            <Run Text="Double-click files in Explorer to open" /><LineBreak />
                                            <Run Text="Right-click panel title for Move To / View Mode" />
                                        </TextBlock>
                                        <TextBlock Foreground="#555555" FontSize="11" TextAlignment="Center"
                                                   Margin="0,24,0,0">
                                            <Run Text="Powered by AvalonDock.Core + AvalonDock.Mvvm + DI" />
                                        </TextBlock>
                                    </StackPanel>
                                </Border>
                            </avalonDock:LayoutDocument>
                        </avalonDock:LayoutDocumentPane>
                    </avalonDock:LayoutDocumentPaneGroup>
                </avalonDock:LayoutPanel>
            </avalonDock:LayoutRoot>
        </avalonDock:ToggleDockingManager>

        <!-- Status bar -->
        <Border Grid.Row="2" Background="#252729" Padding="8,4">
            <Grid>
                <TextBlock Text="Ready" Foreground="#808080" FontSize="11" />
                <TextBlock HorizontalAlignment="Right" Foreground="#808080" FontSize="11">
                    <Run Text="AvalonDock v5.0.0" />
                    <Run Text=" • " />
                    <Run Text="ToggleDockingManager" />
                    <Run Text=" • " />
                    <Run Text="MVVM + DI" />
                </TextBlock>
            </Grid>
        </Border>
    </Grid>
</Window>
