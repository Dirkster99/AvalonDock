<UserControl x:Class="ToggleTestApp.Views.FolderExplorerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:ToggleTestApp.ViewModels"
             xmlns:views="clr-namespace:ToggleTestApp.Views"
             Background="{DynamicResource AppPanelBg}">
    <UserControl.Resources>
        <views:FileIconConverter x:Key="FileIconConverter" />
        <views:FileColorConverter x:Key="FileColorConverter" />

        <HierarchicalDataTemplate DataType="{x:Type vm:FileTreeItem}"
                                  ItemsSource="{Binding Children}">
            <StackPanel Orientation="Horizontal" Margin="2,1">
                <!-- Folder/File icon -->
                <TextBlock Text="{Binding IsDirectory, Converter={StaticResource FileIconConverter}}"
                           FontFamily="Segoe MDL2 Assets" FontSize="12"
                           Foreground="{Binding IsDirectory, Converter={StaticResource FileColorConverter}}"
                           Margin="0,0,6,0" VerticalAlignment="Center" />
                <TextBlock Text="{Binding Name}" Foreground="{DynamicResource AppText}" FontSize="12"
                           VerticalAlignment="Center" />
            </StackPanel>
        </HierarchicalDataTemplate>
    </UserControl.Resources>
    <Grid>
        <TreeView ItemsSource="{Binding RootItems}"
                  Background="Transparent" BorderThickness="0"
                  VirtualizingPanel.IsVirtualizing="True"
                  MouseDoubleClick="OnTreeViewItemDoubleClick">
            <TreeView.ItemContainerStyle>
                <Style TargetType="TreeViewItem">
                    <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}" />
                    <Setter Property="Foreground" Value="{DynamicResource AppText}" />
                    <EventSetter Event="Expanded" Handler="OnTreeViewItemExpanded" />
                    <Style.Triggers>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter Property="Background" Value="{DynamicResource AppSelection}" />
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </TreeView.ItemContainerStyle>
        </TreeView>
    </Grid>
</UserControl>
