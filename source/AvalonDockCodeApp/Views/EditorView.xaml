<UserControl x:Class="ToggleTestApp.Views.EditorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:avalonedit="http://icsharpcode.net/sharpdevelop/avalonedit"
             Background="#1E1E1E">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- File path bar -->
        <Border Grid.Row="0" Background="#252526" Padding="8,4">
            <TextBlock Text="{Binding FilePath}" Foreground="#808080" FontSize="11"
                       FontFamily="Cascadia Mono,Consolas" TextTrimming="CharacterEllipsis" />
        </Border>

        <avalonedit:TextEditor Grid.Row="1"
                               x:Name="Editor"
                               FontFamily="Cascadia Mono,Consolas,Courier New"
                               FontSize="13"
                               Background="#1E1E1E"
                               Foreground="#D4D4D4"
                               ShowLineNumbers="True"
                               LineNumbersForeground="#858585"
                               IsReadOnly="True"
                               HorizontalScrollBarVisibility="Auto"
                               VerticalScrollBarVisibility="Auto"
                               Padding="4" />
    </Grid>
</UserControl>
