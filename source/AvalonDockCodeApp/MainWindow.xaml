<Window x:Class="ToggleTestApp.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:avalonDock="https://github.com/Dirkster99/AvalonDock"
    xmlns:avalonDockControls="clr-namespace:AvalonDock.Controls;assembly=AvalonDock"
    xmlns:avalonDockThemes="clr-namespace:AvalonDock.Themes;assembly=AvalonDock.Themes.Arc"
    xmlns:views="clr-namespace:ToggleTestApp.Views"
    xmlns:vm="clr-namespace:ToggleTestApp.ViewModels"
    Title="AvalonDock Code — Toggle Docking Demo"
    Width="1100" Height="700"
    WindowStartupLocation="CenterScreen"
    Background="{Binding Background, ElementName=dockManager}"
    UseLayoutRounding="True">
    <Window.Resources>
        <views:FileIconConverter x:Key="FileIconConverter" />
        <views:FileColorConverter x:Key="FileColorConverter" />
        <views:NullToCollapsedConverter x:Key="NullToCollapsedConverter" />
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter" />

        <!-- Theme-adaptive app colors (updated in code-behind on theme switch) -->
        <SolidColorBrush x:Key="AppPanelBg" Color="#252526" />
        <SolidColorBrush x:Key="AppEditorBg" Color="#1E1E1E" />
        <SolidColorBrush x:Key="AppInputBg" Color="#3C3C3C" />
        <SolidColorBrush x:Key="AppInputBarBg" Color="#2D2D2D" />
        <SolidColorBrush x:Key="AppText" Color="#CCCCCC" />
        <SolidColorBrush x:Key="AppSubText" Color="#808080" />
        <SolidColorBrush x:Key="AppDimText" Color="#555555" />
        <SolidColorBrush x:Key="AppEditorText" Color="#D4D4D4" />
        <SolidColorBrush x:Key="AppLineNumbers" Color="#858585" />
        <SolidColorBrush x:Key="AppScrollbarBg" Color="#2B2B2B" />
        <SolidColorBrush x:Key="AppSelection" Color="#094771" />

        <!-- Compact scrollbar style -->
        <Style TargetType="ScrollBar">
            <Setter Property="Background" Value="{DynamicResource AppScrollbarBg}" />
            <Setter Property="Width" Value="10" />
            <Setter Property="MinWidth" Value="10" />
            <Style.Triggers>
                <Trigger Property="Orientation" Value="Horizontal">
                    <Setter Property="Height" Value="10" />
                    <Setter Property="MinHeight" Value="10" />
                    <Setter Property="Width" Value="Auto" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="ScrollViewer">
            <Setter Property="Background" Value="Transparent" />
        </Style>

        <!-- DataTemplate: how to render each toolbox VM's content -->
        <DataTemplate DataType="{x:Type vm:FolderExplorerViewModel}">
            <views:FolderExplorerView />
        </DataTemplate>

        <DataTemplate DataType="{x:Type vm:TerminalViewModel}">
            <views:TerminalView />
        </DataTemplate>

        <DataTemplate DataType="{x:Type vm:SearchViewModel}">
            <views:SearchView />
        </DataTemplate>

        <DataTemplate DataType="{x:Type vm:SourceControlViewModel}">
            <views:SourceControlView />
        </DataTemplate>

        <DataTemplate DataType="{x:Type vm:ProblemsViewModel}">
            <Border Background="{DynamicResource AppEditorBg}" Padding="12">
                <TextBlock Text="{Binding Status}"
                           Foreground="{DynamicResource AppSubText}" FontSize="12" />
            </Border>
        </DataTemplate>

        <!-- DataTemplate: how to render document content -->
        <DataTemplate DataType="{x:Type vm:EditorTabViewModel}">
            <views:EditorView />
        </DataTemplate>

        <!-- Document header template (tab header with icon + title) -->
        <DataTemplate x:Key="DocumentTabHeaderTemplate">
            <StackPanel Orientation="Horizontal">
                <Image Source="{Binding IconSource}" Width="14" Height="14"
                       Margin="0,0,5,0" VerticalAlignment="Center"
                       Visibility="{Binding IconSource, Converter={StaticResource NullToCollapsedConverter}}" />
                <TextBlock Text="{Binding Title}" TextTrimming="CharacterEllipsis"
                           VerticalAlignment="Center" />
            </StackPanel>
        </DataTemplate>

        <!-- LayoutItem style selector: different styles for toolboxes vs documents -->
        <views:PanesStyleSelector x:Key="PanesStyleSelector">
            <views:PanesStyleSelector.ToolboxStyle>
                <Style TargetType="{x:Type avalonDockControls:LayoutAnchorableItem}">
                    <Setter Property="Title" Value="{Binding Model.Title}" />
                    <Setter Property="ContentId" Value="{Binding Model.ContentId}" />
                    <Setter Property="ClipToBounds" Value="True" />
                </Style>
            </views:PanesStyleSelector.ToolboxStyle>
            <views:PanesStyleSelector.DocumentStyle>
                <Style TargetType="{x:Type avalonDockControls:LayoutDocumentItem}">
                    <Setter Property="Title" Value="{Binding Model.Title}" />
                    <Setter Property="ToolTip" Value="{Binding Model.ToolTip}" />
                    <Setter Property="IconSource" Value="{Binding Model.IconSource}" />
                    <Setter Property="ContentId" Value="{Binding Model.ContentId}" />
                </Style>
            </views:PanesStyleSelector.DocumentStyle>
        </views:PanesStyleSelector>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Title bar / Menu -->
        <Grid Grid.Row="0" Background="{Binding Background, ElementName=dockManager}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <Menu Grid.Column="0" Background="Transparent"
                  Foreground="{DynamicResource AppText}" Padding="4,4">
                <Menu.Resources>
                    <Style TargetType="MenuItem">
                        <Setter Property="Foreground" Value="{DynamicResource AppText}" />
                        <Style.Triggers>
                            <Trigger Property="Role" Value="SubmenuHeader">
                                <Setter Property="Foreground" Value="Black" />
                            </Trigger>
                            <Trigger Property="Role" Value="SubmenuItem">
                                <Setter Property="Foreground" Value="Black" />
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Menu.Resources>
                <MenuItem Header="_File">
                    <MenuItem Header="_Open Folder..." Command="{Binding OpenFolderCommand}" />
                    <Separator />
                    <MenuItem Header="E_xit" Click="OnExit" />
                </MenuItem>
                <MenuItem Header="_View">
                    <MenuItem Header="Layout Priority">
                        <MenuItem x:Name="menuBottomFullWidth" Header="Bottom Full Width (Rider)"
                                  IsCheckable="True" IsChecked="True" Click="OnLayoutPriorityChanged" />
                        <MenuItem x:Name="menuSidesFullHeight" Header="Sides Full Height (VSCode)"
                                  IsCheckable="True" Click="OnLayoutPriorityChanged" />
                        <MenuItem x:Name="menuDefaultPriority" Header="Default (No Restructuring)"
                                  IsCheckable="True" Click="OnLayoutPriorityChanged" />
                    </MenuItem>
                    <Separator />
                    <MenuItem Header="Theme">
                        <MenuItem x:Name="menuArcDark" Header="Arc Dark"
                                  IsCheckable="True" IsChecked="True" Click="OnThemeChanged" />
                        <MenuItem x:Name="menuArcLight" Header="Arc Light"
                                  IsCheckable="True" Click="OnThemeChanged" />
                        <Separator />
                        <MenuItem x:Name="menuVs2015Dark" Header="VS2015 Dark"
                                  IsCheckable="True" Click="OnThemeChanged" />
                        <MenuItem x:Name="menuVs2015Light" Header="VS2015 Light"
                                  IsCheckable="True" Click="OnThemeChanged" />
                        <MenuItem x:Name="menuVs2015Blue" Header="VS2015 Blue"
                                  IsCheckable="True" Click="OnThemeChanged" />
                    </MenuItem>
                </MenuItem>
            </Menu>
            <TextBlock Grid.Column="1" Text="AvalonDock Code — Toggle Docking Demo"
                       Foreground="{DynamicResource AppSubText}" FontSize="12"
                       HorizontalAlignment="Center" VerticalAlignment="Center" />

            <!-- Layout toggle buttons (VS Code style) -->
            <StackPanel Grid.Column="2" Orientation="Horizontal" Margin="0,0,8,0"
                        VerticalAlignment="Center">
                <StackPanel.Resources>
                    <Style x:Key="LayoutToggleButton" TargetType="ToggleButton">
                        <Setter Property="Width" Value="26" />
                        <Setter Property="Height" Value="22" />
                        <Setter Property="Background" Value="Transparent" />
                        <Setter Property="BorderThickness" Value="0" />
                        <Setter Property="Cursor" Value="Hand" />
                        <Setter Property="Margin" Value="1,0" />
                        <Setter Property="Padding" Value="4,3" />
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ToggleButton">
                                	<Border Background="{TemplateBinding Background}"
                                			BorderBrush="{TemplateBinding BorderBrush}"
                                			BorderThickness="{TemplateBinding BorderThickness}"
                                			Padding="{TemplateBinding Padding}"
                                			CornerRadius="3">
                                		<ContentPresenter HorizontalAlignment="Center"
                                						  VerticalAlignment="Center" />
                                	</Border>
                                	<ControlTemplate.Triggers>
                                		<Trigger Property="IsMouseOver" Value="True">
                                			<Setter Property="Background" Value="#30FFFFFF" />
                                		</Trigger>
                                		<Trigger Property="IsChecked" Value="True">
                                			<Setter Property="Background" Value="#20FFFFFF" />
                                		</Trigger>
                                	</ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </StackPanel.Resources>

                <!-- Toggle Primary Side Bar (Left) -->
                <ToggleButton Style="{StaticResource LayoutToggleButton}"
                              ToolTip="Toggle Primary Side Bar"
                              IsChecked="{Binding IsPrimarySideBarOpen, Mode=OneWay}"
                              Command="{Binding TogglePrimarySideBarCommand}">
                    <Viewbox Width="14" Height="14">
                        <Canvas Width="16" Height="16">
                            <Rectangle Width="15" Height="13" RadiusX="1" RadiusY="1"
                                	   StrokeThickness="1" Fill="Transparent"
                                	   Stroke="{DynamicResource AppSubText}"
                                	   Canvas.Left="0.5" Canvas.Top="1.5" />
                            <Rectangle Width="4.5" Height="11" Fill="{DynamicResource AppSubText}"
                                	   Opacity="0.4" Canvas.Left="1.5" Canvas.Top="2.5" />
                        </Canvas>
                    </Viewbox>
                </ToggleButton>

                <!-- Toggle Panel (Bottom) -->
                <ToggleButton Style="{StaticResource LayoutToggleButton}"
                              ToolTip="Toggle Panel"
                              IsChecked="{Binding IsBottomPanelOpen, Mode=OneWay}"
                              Command="{Binding ToggleBottomPanelCommand}">
                    <Viewbox Width="14" Height="14">
                        <Canvas Width="16" Height="16">
                            <Rectangle Width="15" Height="13" RadiusX="1" RadiusY="1"
                                	   StrokeThickness="1" Fill="Transparent"
                                	   Stroke="{DynamicResource AppSubText}"
                                	   Canvas.Left="0.5" Canvas.Top="1.5" />
                            <Rectangle Width="13" Height="4.5" Fill="{DynamicResource AppSubText}"
                                	   Opacity="0.4" Canvas.Left="1.5" Canvas.Top="9" />
                        </Canvas>
                    </Viewbox>
                </ToggleButton>

                <!-- Toggle Secondary Side Bar (Right) -->
                <ToggleButton Style="{StaticResource LayoutToggleButton}"
                              ToolTip="Toggle Secondary Side Bar"
                              IsChecked="{Binding IsSecondarySideBarOpen, Mode=OneWay}"
                              Command="{Binding ToggleSecondarySideBarCommand}">
                    <Viewbox Width="14" Height="14">
                        <Canvas Width="16" Height="16">
                            <Rectangle Width="15" Height="13" RadiusX="1" RadiusY="1"
                                	   StrokeThickness="1" Fill="Transparent"
                                	   Stroke="{DynamicResource AppSubText}"
                                	   Canvas.Left="0.5" Canvas.Top="1.5" />
                            <Rectangle Width="4.5" Height="11" Fill="{DynamicResource AppSubText}"
                                	   Opacity="0.4" Canvas.Left="10" Canvas.Top="2.5" />
                        </Canvas>
                    </Viewbox>
                </ToggleButton>
            </StackPanel>
        </Grid>

        <!-- Dock Manager -->
        <avalonDock:ToggleDockingManager x:Name="dockManager" Grid.Row="1"
                                         BorderThickness="0"
                                         DockLayout="{Binding DockLayout}"
                                         DocumentHeaderTemplate="{StaticResource DocumentTabHeaderTemplate}"
                                         LayoutItemContainerStyleSelector="{StaticResource PanesStyleSelector}">
            <avalonDock:ToggleDockingManager.Theme>
                <avalonDockThemes:ArcDarkTheme />
            </avalonDock:ToggleDockingManager.Theme>
            <avalonDock:LayoutRoot>
                <avalonDock:LayoutPanel Orientation="Horizontal">
                    <avalonDock:LayoutDocumentPaneGroup>
                        <avalonDock:LayoutDocumentPane x:Name="LayoutDocumentPane">
                            <avalonDock:LayoutDocument Title="Welcome" ContentId="welcome">
                                <Border Background="{DynamicResource AppEditorBg}" Padding="40">
                                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                        <TextBlock Text="AvalonDock Code" FontSize="28" FontWeight="Light"
                                                   Foreground="{DynamicResource AppText}" HorizontalAlignment="Center" />
                                        <TextBlock Text="Toggle Docking Demo — v5.0.0" FontSize="14"
                                                   Foreground="{DynamicResource AppSubText}" HorizontalAlignment="Center" Margin="0,8,0,24" />
                                        <TextBlock Foreground="{DynamicResource AppSubText}" FontSize="13" TextAlignment="Center" LineHeight="24">
                                            <Run Text="Click sidebar icons to toggle panels" /><LineBreak />
                                            <Run Text="Drag buttons between zones to rearrange" /><LineBreak />
                                            <Run Text="Double-click files in Explorer to open" />
                                        </TextBlock>
                                        <TextBlock Foreground="{DynamicResource AppDimText}" FontSize="11" TextAlignment="Center"
                                                   Margin="0,24,0,0">
                                            <Run Text="Powered by AvalonDock + AvalonDock.Mvvm + AvalonDock-DependencyInjection" />
                                        </TextBlock>
                                    </StackPanel>
                                </Border>
                            </avalonDock:LayoutDocument>
                        </avalonDock:LayoutDocumentPane>
                    </avalonDock:LayoutDocumentPaneGroup>
                </avalonDock:LayoutPanel>
            </avalonDock:LayoutRoot>
        </avalonDock:ToggleDockingManager>

        <!-- Status bar -->
        <Border Grid.Row="2" Background="{Binding Background, ElementName=dockManager}" Padding="8,4">
            <Grid>
                <TextBlock Text="Ready" Foreground="{DynamicResource AppSubText}" FontSize="11" />
                <TextBlock HorizontalAlignment="Right" Foreground="{DynamicResource AppSubText}" FontSize="11">
                    <Run Text="AvalonDock v5.0.0" />
                    <Run Text=" • " />
                    <Run Text="ToggleDockingManager" />
                    <Run Text=" • " />
                    <Run Text="MVVM + DI" />
                </TextBlock>
            </Grid>
        </Border>
    </Grid>
</Window>
